---
import type { ContentItem } from '../lib/scan-content';
import type { Kind } from '../lib/build-install-cmd';
import InstallCTA from './InstallCTA.astro';

interface Props {
  kind: Kind;
  item: ContentItem;
}

const { kind, item } = Astro.props;
const section = kind === 'skill' ? 'skills' : 'agents';
const href = `${import.meta.env.BASE_URL}${section}/${item.slug}`;
const badge = kind === 'skill' ? item.version : item.model;
const badgePrefix = kind === 'skill' ? 'v' : '';
---

<div class="group flex flex-col rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition hover:border-indigo-400/60 hover:bg-slate-900">
  <a href={href} class="flex flex-1 flex-col">
    <div class="flex items-center justify-between gap-2">
      <h3 class="font-semibold text-white">{item.name}</h3>
      {badge && <span class="text-xs text-slate-500">{badgePrefix}{badge}</span>}
    </div>
    <p class="mt-2 flex-1 text-sm text-slate-300">{item.description}</p>
    {
      item.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {item.tags.slice(0, 4).map((t) => (
            <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">{t}</span>
          ))}
        </div>
      )
    }
    <span class="mt-4 text-sm font-medium text-indigo-400 group-hover:underline">View {kind} →</span>
  </a>
  <div class="mt-3 border-t border-slate-800 pt-3">
    <InstallCTA kind={kind} label="Install" variant="outline" full />
  </div>
</div>
