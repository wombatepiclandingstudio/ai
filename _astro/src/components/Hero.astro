---
const GITHUB_URL = 'https://github.com/wombatepiclandingstudio/ai';
---

<section class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_50%_at_50%_0%,theme(colors.indigo.500/0.18),transparent)]"></div>
  <div class="mx-auto max-w-5xl px-4 py-20 text-center sm:py-28">
    <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-3 py-1 text-xs text-slate-300">
      Open Agent Skills standard
    </p>
    <h1 class="mx-auto max-w-3xl text-4xl font-bold tracking-tight sm:text-6xl">
      Reusable AI <span class="text-indigo-400">skills</span> &amp; <span class="text-indigo-400">agents</span>
      for your coding tools
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-slate-300">
      A personal toolbox of plug-and-play skills and agent definitions. Install them into Claude,
      Codex, Cursor, Kilo, OpenCode and more with a single shell command.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-indigo-500 px-5 py-2.5 font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:bg-indigo-400"
      >
        ★ Star on GitHub
      </a>
      <a
        href="#install"
        class="rounded-lg border border-slate-700 px-5 py-2.5 font-semibold text-slate-100 transition hover:border-indigo-400"
      >
        Install in seconds
      </a>
    </div>
  </div>
</section>
