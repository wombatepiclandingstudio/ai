---
const GITHUB_URL = 'https://github.com/wombatepiclandingstudio/ai';
---

<section class="relative overflow-hidden border-y border-slate-800 bg-slate-900/40">
  <div class="mx-auto max-w-3xl px-4 py-16 text-center">
    <h2 class="text-2xl font-bold sm:text-3xl">Found something useful?</h2>
    <p class="mt-3 text-slate-300">
      Star the repository to keep it handy and see new skills &amp; agents as they're added.
    </p>
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener"
      class="mt-6 inline-block rounded-lg bg-indigo-500 px-6 py-3 font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:bg-indigo-400"
    >
      ★ Star wombatepiclandingstudio/ai
    </a>
  </div>
</section>
