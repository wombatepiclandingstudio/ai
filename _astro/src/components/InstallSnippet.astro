---
interface Props {
  lang?: string;
  command: string;
}
const { lang = 'bash', command } = Astro.props;
---

<figure class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
  <figcaption class="flex items-center justify-between border-b border-slate-800 px-4 py-2 text-xs text-slate-400">
    <span>{lang}</span>
  </figcaption>
  <pre class="overflow-x-auto px-4 py-3 text-sm"><code class="text-slate-200">{command}</code></pre>
</figure>
