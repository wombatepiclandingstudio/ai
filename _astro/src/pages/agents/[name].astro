---
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getAgents } from '../../lib/scan-content';

export async function getStaticPaths() {
  const agents = await getAgents();
  return agents.map((a) => ({ params: { name: a.slug }, props: { item: a } }));
}

const { item } = Astro.props;
const html = marked.parse(item.body, { async: false }) as string;
---

<Base title={`${item.name} — agent`} description={item.description}>
  <Navbar />
  <main class="mx-auto max-w-3xl px-4 py-12">
    <a href={`${import.meta.env.BASE_URL}#agents`} class="text-sm text-indigo-400 hover:underline">← All agents</a>
    <header class="mt-6 border-b border-slate-800 pb-6">
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold">{item.name}</h1>
        {item.model && <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">{item.model}</span>}
      </div>
      <p class="mt-3 text-slate-300">{item.description}</p>
      {
        item.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {item.tags.map((t) => (
              <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">{t}</span>
            ))}
          </div>
        )
      }
      {
        (item.license || item.author) && (
          <p class="mt-3 text-xs text-slate-500">
            {item.author && <span>by {item.author}</span>}
            {item.license && <span> · license {item.license}</span>}
          </p>
        )
      }
    </header>
    <article class="prose-invert mt-8 max-w-none text-slate-200 [&_a]:text-indigo-400 [&_a]:underline [&_code]:rounded [&_code]:bg-slate-800 [&_code]:px-1 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:bg-slate-900 [&_pre]:p-4 [&_pre]:text-sm" set:html={html}></article>
  </main>
  <Footer />
</Base>
