---
import { marked } from 'marked';
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SkillCard from '../components/SkillCard.astro';
import AgentCard from '../components/AgentCard.astro';
import InstallSnippet from '../components/InstallSnippet.astro';
import StarCTA from '../components/StarCTA.astro';
import Footer from '../components/Footer.astro';
import { getSkills, getAgents } from '../lib/scan-content';

const skills = await getSkills();
const agents = await getAgents();

const skillCmd =
  'bash install-skill.sh --tool claude,codex,cursor,kilocode,opencode --target /path/to/project';
const agentCmd =
  'bash install-agent.sh --tool claude,opencode,kiro --target /path/to/project';
const skillCmdWin =
  'pwsh install-skill.ps1 -Tool claude,codex,cursor,kilocode,opencode -Target C:\\path\\to\\project';
const agentCmdWin =
  'pwsh install-agent.ps1 -Tool claude,opencode,kiro -Target C:\\path\\to\\project';
---

<Base title="AI skills & agents — reusable toolbox for your coding tools">
  <Navbar />
  <main>
    <Hero />

    <section id="skills" class="mx-auto max-w-5xl px-4 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold sm:text-3xl">Skills</h2>
          <p class="mt-2 text-slate-400">Reusable capabilities following the open Agent Skills standard.</p>
        </div>
        <span class="text-sm text-slate-500">{skills.length} available</span>
      </div>
      {
        skills.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {skills.map((s) => <SkillCard item={s} />)}
          </div>
        ) : (
          <p class="rounded-xl border border-dashed border-slate-800 p-8 text-center text-slate-500">
            No skills found in the repository yet.
          </p>
        )
      }
    </section>

    <section id="agents" class="mx-auto max-w-5xl px-4 py-16">
      <div class="mb-8 flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold sm:text-3xl">Agents</h2>
          <p class="mt-2 text-slate-400">Named subagent definitions you can drop into your tools.</p>
        </div>
        <span class="text-sm text-slate-500">{agents.length} available</span>
      </div>
      {
        agents.length > 0 ? (
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {agents.map((a) => <AgentCard item={a} />)}
          </div>
        ) : (
          <p class="rounded-xl border border-dashed border-slate-800 p-8 text-center text-slate-500">
            No agents found in the repository yet.
          </p>
        )
      }
    </section>

    <section id="install" class="mx-auto max-w-5xl px-4 py-16">
      <h2 class="text-2xl font-bold sm:text-3xl">Install in seconds</h2>
      <p class="mt-2 text-slate-400">
        Skills and agents are exposed by symlinking their folders into each tool's discovery path.
        No code generation, no rewrites — one canonical file works everywhere.
      </p>
      <div class="mt-8 grid gap-6 lg:grid-cols-2">
        <div>
          <h3 class="mb-3 text-lg font-semibold text-white">Skills</h3>
          <InstallSnippet command={skillCmd} />
          <p class="mt-3 text-xs text-slate-500">Windows (PowerShell):</p>
          <div class="mt-1">
            <InstallSnippet command={skillCmdWin} />
          </div>
        </div>
        <div>
          <h3 class="mb-3 text-lg font-semibold text-white">Agents</h3>
          <InstallSnippet command={agentCmd} />
          <p class="mt-3 text-xs text-slate-500">Windows (PowerShell):</p>
          <div class="mt-1">
            <InstallSnippet command={agentCmdWin} />
          </div>
        </div>
      </div>
    </section>

    <StarCTA />
  </main>
  <Footer />
</Base>
