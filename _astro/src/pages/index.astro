---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import InstallModal from '../components/InstallModal.astro';
import InstallCTA from '../components/InstallCTA.astro';
import StarCTA from '../components/StarCTA.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Skills & agents for your coding tools — Wombat Epic Landing Studio AI">
  <main>
    <Hero />

    <section id="install" class="mx-auto max-w-5xl px-4 py-16">
      <h2 class="text-2xl font-bold sm:text-3xl">Install</h2>
      <p class="mt-2 max-w-2xl text-slate-400">
        Each skill and agent installs by symlinking its folder into a tool's discovery
        path — no code generation, no rewrites. Hit <strong class="text-slate-200">Install</strong>
        on any card or detail page to build the exact command for your tools and copy it.
      </p>
      <p class="mt-3 text-sm text-slate-500">
        Prefer to run it directly? The installers are also served from this site:
        <a class="text-indigo-400 hover:underline" href={`${import.meta.env.BASE_URL}install-skill.sh`}>install-skill.sh</a>,
        <a class="text-indigo-400 hover:underline" href={`${import.meta.env.BASE_URL}install-agent.sh`}>install-agent.sh</a>
        (plus <code class="rounded bg-slate-800 px-1">.ps1</code> variants for Windows). When
        downloaded on their own they clone the repo into a temp dir, so they work without a checkout.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
          <h3 class="font-semibold text-white">Install a skill</h3>
          <p class="mt-1 text-sm text-slate-400">Builds a command for install-skill.sh.</p>
          <div class="mt-4"><InstallCTA kind="skill" full /></div>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
          <h3 class="font-semibold text-white">Install an agent</h3>
          <p class="mt-1 text-sm text-slate-400">Builds a command for install-agent.sh.</p>
          <div class="mt-4"><InstallCTA kind="agent" full /></div>
        </div>
      </div>
    </section>

    <StarCTA />
  </main>
  <Footer />

  <InstallModal kind="skill" />
  <InstallModal kind="agent" />
</Base>
