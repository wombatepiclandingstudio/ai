---
import Base from '../../layouts/Base.astro';
import ContentCard from '../../components/ContentCard.astro';
import Footer from '../../components/Footer.astro';
import InstallModal from '../../components/InstallModal.astro';
import { getSkills } from '../../lib/scan-content';

const skills = await getSkills();
---

<Base title="Skills — Wombat Epic Landing Studio AI" description="Ready-made skills you can drop into Claude, Codex, Cursor, Kilo, OpenCode and more.">
  <main class="mx-auto max-w-5xl px-4 py-16">
    <div class="mb-8 flex items-end justify-between">
      <div>
        <h1 class="text-3xl font-bold">Skills</h1>
        <p class="mt-2 text-slate-400">
          Ready-made skills — point the installer at a project or your home folder
          and they show up in your tools.
        </p>
      </div>
      <span class="text-sm text-slate-500">{skills.length} available</span>
    </div>
    {
      skills.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {skills.map((s) => <ContentCard kind="skill" item={s} />)}
        </div>
      ) : (
        <p class="rounded-xl border border-dashed border-slate-800 p-8 text-center text-slate-500">
          No skills found in the repository yet.
        </p>
      )
    }
  </main>
  <Footer />
  <InstallModal kind="skill" />
</Base>
