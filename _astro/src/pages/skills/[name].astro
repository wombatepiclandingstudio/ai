---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import InstallCTA from '../../components/InstallCTA.astro';
import InstallModal from '../../components/InstallModal.astro';
import { getSkills } from '../../lib/scan-content';

export async function getStaticPaths() {
  const skills = await getSkills();
  return skills.map((s) => ({ params: { name: s.slug }, props: { item: s } }));
}

const { item } = Astro.props;
const body = item.body;
---

<Base title={`${item.name} — skill`} description={item.description}>
  <Navbar />
  <main class="mx-auto max-w-3xl px-4 py-12">
    <a href={`${import.meta.env.BASE_URL}#skills`} class="text-sm text-indigo-400 hover:underline">← All skills</a>
    <header class="mt-6 border-b border-slate-800 pb-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-3">
          <h1 class="text-3xl font-bold">{item.name}</h1>
          {item.version && <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">v{item.version}</span>}
        </div>
        <InstallCTA kind="skill" />
      </div>
      <p class="mt-3 text-slate-300">{item.description}</p>
      {
        item.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {item.tags.map((t) => (
              <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300">{t}</span>
            ))}
          </div>
        )
      }
      {
        (item.license || item.author) && (
          <p class="mt-3 text-xs text-slate-500">
            {item.author && <span>by {item.author}</span>}
            {item.license && <span> · license {item.license}</span>}
          </p>
        )
      }
    </header>

    <div class="mt-6 flex items-center gap-2" data-md-toggle>
      <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">View</span>
      <div class="inline-flex overflow-hidden rounded-lg border border-slate-700">
        <button type="button" data-md-mode="rendered" class="px-3 py-1.5 text-sm font-medium text-white bg-indigo-500/20 border-r border-slate-700">Rendered</button>
        <button type="button" data-md-mode="source" class="px-3 py-1.5 text-sm font-medium text-slate-300 hover:bg-slate-800">Source</button>
      </div>
    </div>

    <article
      class="prose-invert mt-4 max-w-none text-slate-200 [&_a]:text-indigo-400 [&_a]:underline [&_code]:rounded [&_code]:bg-slate-800 [&_code]:px-1 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:bg-slate-900 [&_pre]:p-4 [&_pre]:text-sm"
      data-md-article
      data-md-source={body}
    ></article>

    <pre class="hidden mt-4 overflow-x-auto rounded-xl border border-slate-800 bg-slate-950 p-4 text-sm text-slate-200" data-md-source-view></pre>
  </main>
  <Footer />
  <InstallModal kind="skill" />
</Base>

<script>
  import { initMarkdownToggles } from '../../lib/md-toggle';

  initMarkdownToggles();
</script>
